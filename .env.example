# Runtime
APP_ENV=local
PUBLIC_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8080
API_KEY=
API_KEY_HEADER=X-API-Key
MAX_UPLOAD_BYTES=104857600
MAX_BATCH_FILES=100
MAX_BATCH_BYTES=1073741824

# Postgres
DATABASE_URL=postgresql://document_agent:document_agent@postgres:5432/document_agent
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_BUCKET=document-agent
MINIO_AUTO_CREATE_BUCKET=true

# Worker
WORKER_ID=
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_LEASE_SECONDS=300
WORKER_LEASE_HEARTBEAT_SECONDS=30
WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=8081
JOB_MAX_ATTEMPTS=3
JOB_TIMEOUT_SECONDS=3600
BATCH_TIMEOUT_SECONDS=14400
STAGING_TTL_SECONDS=86400

# OCR
# OCR_SERVER_URL accepts either a provider base URL or a full /chat/completions URL.
OCR_SERVER_URL=
OCR_API_KEY=
OCR_MODEL=allenai/olmOCR-2-7B-1025-FP8
OCR_PAGE_MAX_TOKENS=8000
OCR_TARGET_LONGEST_IMAGE_DIM=1288
OCR_MAX_CONCURRENT_REQUESTS=2

# Conversion
MAX_PDF_PAGES=500
PANDOC_BIN=pandoc
LIBREOFFICE_BIN=soffice
PDF_USE_VENDOR_EXTRACTOR=true
